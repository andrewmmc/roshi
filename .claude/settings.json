{
  "permissions": {
    "allow": ["Bash(npx eslint:*)", "Bash(npx tsc:*)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-check.sh",
            "timeout": 30,
            "statusMessage": "Checking lint & types..."
          }
        ]
      }
    ]
  }
}
