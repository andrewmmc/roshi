require 'json'

default_platform(:mac)

APP_BUNDLE_ID = ENV['APP_IDENTIFIER'] || 'com.roshi.desktop'

def pkg_version
  pkg_path = File.expand_path('../package.json', __dir__)
  JSON.parse(File.read(pkg_path)).fetch('version')
end

def asc_api_key_from_env
  key_path = ENV['APPLE_API_KEY_PATH']
  key_id = ENV['APPLE_API_KEY']
  issuer_id = ENV['APPLE_API_ISSUER']

  missing = []
  missing << 'APPLE_API_KEY_PATH' if key_path.nil? || key_path.empty?
  missing << 'APPLE_API_KEY' if key_id.nil? || key_id.empty?
  missing << 'APPLE_API_ISSUER' if issuer_id.nil? || issuer_id.empty?
  unless missing.empty?
    UI.user_error!("Missing required environment variables for App Store Connect API key: #{missing.join(', ')}")
  end

  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer_id,
    key_filepath: key_path,
    in_house: false
  )
end

def resolved_build_number(api_key, version)
  override = ENV['MAC_BUILD_NUMBER']
  return override if override && !override.empty?

  latest = latest_testflight_build_number(
    api_key: api_key,
    version: version,
    app_identifier: APP_BUNDLE_ID,
    platform: 'osx',
    initial_build_number: nil
  )
  UI.user_error!("No TestFlight build found for version #{version}. Set MAC_BUILD_NUMBER or wait for processing to finish.") if latest.nil?
  latest.to_s
end

platform :mac do
  desc 'Push App Store version + localized release notes (no review submission).'
  lane :release_appstore do |options|
    version = options[:version] || pkg_version
    api_key = asc_api_key_from_env
    build_number = options[:build_number] || resolved_build_number(api_key, version)
    submit_for_review = options.fetch(:submit_for_review, false)
    release_type = options[:release_type] || 'manual'
    phased_release = release_type == 'phased'
    automatic_release = release_type == 'automatic'

    UI.message("Releasing #{version} (build #{build_number}) — release_type=#{release_type}, submit_for_review=#{submit_for_review}")

    deliver(
      api_key: api_key,
      app_identifier: APP_BUNDLE_ID,
      platform: 'osx',
      app_version: version,
      build_number: build_number,
      metadata_path: File.expand_path('metadata', __dir__),
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      skip_app_version_update: false,
      force: true,
      precheck_include_in_app_purchases: false,
      submit_for_review: submit_for_review,
      automatic_release: automatic_release,
      phased_release: phased_release,
      reset_ratings: false,
      run_precheck_before_submit: submit_for_review
    )
  end

  desc 'Dry-run: validate metadata locally without uploading.'
  lane :release_appstore_dry_run do |options|
    version = options[:version] || pkg_version
    UI.message("Validating metadata for #{version} (no upload).")

    deliver(
      app_identifier: APP_BUNDLE_ID,
      platform: 'osx',
      app_version: version,
      metadata_path: File.expand_path('metadata', __dir__),
      skip_binary_upload: true,
      skip_screenshots: true,
      verify_only: true,
      force: true
    )
  end
end
